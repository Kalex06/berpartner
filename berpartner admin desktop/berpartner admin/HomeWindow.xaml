<Window x:Class="berpartner_admin.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:berpartner_admin"
        mc:Ignorable="d"
        Title="HomeWindow" Height="450" Width="800" Icon="/logo_icon.ico" Loaded="Window_Loaded">
    <Grid Background="DarkBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Height="50" Background="#FF0A1A5A">
            <Image Source="/logo_2.png" Margin="20,1"></Image>
            <Button  Padding="10" Margin="5" FontSize="15" Background="#FF07398A" Foreground="AliceBlue" Click="Button_Click">🏠︎ Kezdőlap</Button>
            <Button  Padding="10" Margin="5" FontSize="15" Background="#FF07398A" Foreground="AliceBlue">✎ Táblák szerkesztése</Button>
            <Button  Padding="10" Margin="5" FontSize="15" Background="#FF07398A" Foreground="AliceBlue" Click="Button_Click_1">✉ Üzenet küldés</Button>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"></Frame>
     
    </Grid>
</Window>

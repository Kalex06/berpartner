<Page x:Class="berpartner_admin.MessagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:berpartner_admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MessagePage">

    <Grid Background="DarkBlue">
        
        
        <Label Foreground="AliceBlue" Margin="0,0,360,300" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20">Tárgy</Label>
        <TextBox Width="400" Height="30" Margin="0,0,0,230" HorizontalAlignment="Center" VerticalAlignment="Center" MaxLength="25" FontSize="18" />
        <Label Foreground="AliceBlue" Margin="0,0,340,130" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20">Üzenet</Label>
        <TextBox Width="400" Height="200" Margin="0,100,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="18" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

    </Grid>
</Page>

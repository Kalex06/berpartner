<Page x:Class="berpartner_admin.TablesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:berpartner_admin"
      mc:Ignorable="d"
      Title="TablesPage">

    <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
        
    <Grid Background="DarkBlue" Loaded="Grid_Loaded">
        <Label HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,720,400" Foreground="White" FontSize="30">Főkategóriák</Label>
        <ListBox HorizontalAlignment="Center" HorizontalContentAlignment="Stretch" Foreground="White" Background="#FF152B81"  x:Name="ListBoxmainCategories" SelectedValuePath="id" VerticalAlignment="Top" Margin="0,100,600,0" Width="300" Height="400">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>


                        <TextBlock Text="{Binding fo_kategoria}" x:Name="TextDisplay" VerticalAlignment="Center" />
                            
                        <TextBox x:Name="TextEdit" Text="{Binding fo_kategoria, UpdateSourceTrigger=LostFocus}" 
                                VerticalAlignment="Center" Visibility="Collapsed" />
                        
                            <StackPanel x:Name="NormalMode" Orientation="Horizontal" Grid.Column="1">
                                <Button Content="&#xE70F;" Tag="{Binding ElementName=NormalMode}"  Background="#FF2E4ECF" FontSize="18" Foreground="LightGreen" FontFamily="Segoe MDL2 Assets" Click="Edit_Click" Margin="2"/>
                            <Button Content="&#xE74D;" Background="#FF2E4ECF" FontSize="18" Foreground="Red" Click="Delete_Click" FontFamily="Segoe MDL2 Assets" Margin="2"/>
                        </StackPanel>

                        <StackPanel x:Name="EditMode" Orientation="Horizontal" Grid.Column="1" Visibility="Collapsed">
                                <Button Content="&#xE73E;" FontSize="18" FontWeight="Bold"  FontFamily="Segoe MDL2 Assets" Foreground="LightGreen"  Tag="{Binding ElementName=EditMode}"  Click="Save_Click" Background="#FF2E4ECF" Margin="2"/>
                                <Button Content="❌" Foreground="Red" Tag="{Binding ElementName=EditMode}" Click="Cancel_Click" Background="#FF2E4ECF" Margin="2"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Label HorizontalAlignment="Center" VerticalAlignment="Top" Margin="450,40,0,400" Foreground="White" FontSize="30">Kategóriák</Label>
        <ListBox HorizontalAlignment="Center" VerticalAlignment="Top" Margin="600,100,0,0" Width="300" Height="400">

        </ListBox>
        <Label HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,650,770,0" Foreground="White" FontSize="30">Állapotok</Label>
        <ListBox HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,720,600,0" Width="300" Height="400">

        </ListBox>

    </Grid>
    </ScrollViewer>
</Page>
